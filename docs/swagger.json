{
    "consumes": [
        "multipart/form-data"
    ],
    "produces": [
        "application/json"
    ],
    "swagger": "2.0",
    "info": {
        "description": "POC: receives audio, transcribes and analyzes with Google Gemini, persists in MongoDB.",
        "title": "Audio Transcription API",
        "contact": {},
        "version": "1.0"
    },
    "host": "example.com",
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "Returns 200 when the HTTP service is running.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "Service health",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.HealthResponse"
                        }
                    }
                }
            }
        },
        "/transcribe": {
            "post": {
                "description": "Receives an audio file upload, transcribes and analyzes it with Google Gemini,\nand persists the result in MongoDB.",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "transcription"
                ],
                "summary": "Transcribe an audio file",
                "parameters": [
                    {
                        "type": "file",
                        "description": "Audio file (mp3, mp4, wav, m4a, ogg, webm, flac — max 25MB)",
                        "name": "audio",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/domain.TranscriptionRecord"
                        }
                    },
                    "400": {
                        "description": "Missing 'audio' field",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    },
                    "413": {
                        "description": "File exceeds MAX_UPLOAD_BYTES",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error or MongoDB failure",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    },
                    "502": {
                        "description": "Upstream API failure from Gemini",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    },
                    "503": {
                        "description": "Required AI provider is not configured",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/transcriptions": {
            "get": {
                "description": "Returns paginated transcriptions ordered by creation date descending.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "transcription"
                ],
                "summary": "List stored transcriptions",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Number of records to return (default 20)",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Pagination offset (default 0)",
                        "name": "offset",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.TranscriptionRecord"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.TranscriptionRecord": {
            "type": "object",
            "properties": {
                "Id": {
                    "description": "ID is assigned by the application and stored as MongoDB _id.",
                    "type": "string",
                    "example": "67e3e8f6b4f54d9f0cf0aa11"
                },
                "audioDuration": {
                    "type": "number",
                    "example": 47.3
                },
                "audioFilename": {
                    "description": "Audio file metadata.",
                    "type": "string",
                    "example": "meeting.mp3"
                },
                "createdAt": {
                    "description": "Metadata.",
                    "type": "string"
                },
                "fileSizeBytes": {
                    "type": "integer",
                    "example": 2097152
                },
                "keyPoints": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "language": {
                    "type": "string",
                    "example": "en"
                },
                "sentiment": {
                    "type": "string",
                    "example": "positive"
                },
                "summary": {
                    "description": "AI analysis from Google Gemini - stored as nested document, schema-free.",
                    "type": "string"
                },
                "transcript": {
                    "description": "Transcription result from Gemini audio understanding.",
                    "type": "string",
                    "example": "Hello, this is a test recording..."
                }
            }
        },
        "handler.ErrorResponse": {
            "description": "Standardized error response",
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "audio field is required"
                }
            }
        },
        "handler.HealthResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "ok"
                }
            }
        }
    }
}